# PostMortemIQ Environment Configuration

# ============================================================================
# REQUIRED - LLM Provider
# ============================================================================
GROQ_API_KEY=your_groq_api_key_here
# Get your free API key at: https://console.groq.com
# Free tier: 14,400 requests/day
# Model: llama-3.3-70b-versatile

# ============================================================================
# REQUIRED - Graph Database
# ============================================================================
TIGERGRAPH_HOST=https://your-instance.i.tgcloud.io
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=your_password_here
TIGERGRAPH_GRAPH_NAME=IncidentGraph
# Get free TigerGraph Cloud account at: https://tgcloud.io

# ============================================================================
# REQUIRED - Evaluation (for T3: Accuracy Evaluation)
# ============================================================================
HUGGINGFACE_API_TOKEN=your_huggingface_token_here
# Get your token at: https://huggingface.co/settings/tokens
# Used for LLM-as-a-Judge (Mistral-7B)

# ============================================================================
# OPTIONAL - Embeddings
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
# Only needed for embeddings (text-embedding-3-small)
# If not set, will fall back to local sentence-transformers

USE_LOCAL_EMBEDDINGS=false
# Set to 'true' to force local embeddings even when OpenAI key is set
# Local model: sentence-transformers/all-MiniLM-L6-v2 (~80MB)
# Note: Local embeddings may reduce retrieval accuracy by ~3-5%

# ============================================================================
# OPTIONAL - TigerGraph GraphRAG (for T5: Official Alignment)
# ============================================================================
GRAPHRAG_BASE_URL=http://localhost:8000
# Base URL for official TigerGraph GraphRAG Docker container
# Will be set up in T5

# ============================================================================
# OPTIONAL - Caching
# ============================================================================
REDIS_URL=redis://localhost:6379
# Optional Redis for query result caching (5-min TTL)
# If not set, will use in-memory caching

# ============================================================================
# OPTIONAL - Error Resilience & Observability
# ============================================================================
PIPELINE_TIMEOUT_MS=10000
# Timeout for pipeline execution in milliseconds (default: 10000 = 10 seconds)
# If pipeline exceeds this, returns timeout result instead of blocking

LOG_LEVEL=INFO
# Logging level: DEBUG, INFO, WARNING, ERROR
# Structured JSON logs written to logs/run_{timestamp}.jsonl

# ============================================================================
# OPTIONAL - Multi-Provider Fallback
# ============================================================================
TOGETHER_API_KEY=your_together_api_key_here
# Together AI API key for fallback LLM provider
# Get at: https://api.together.xyz

OPENROUTER_API_KEY=your_openrouter_api_key_here
# OpenRouter API key for fallback LLM provider
# Get at: https://openrouter.ai

OLLAMA_API_KEY=your_ollama_api_key_here
# Ollama API Key (if you are using a hosted API like RunPod/Together compatible with Ollama schema)
OLLAMA_HOST=http://localhost:11434
# Your Ollama host url

# ============================================================================
# NOTES
# ============================================================================
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env to version control (it's in .gitignore)
# 3. All services have free tiers available for development/testing
# 4. For production, consider upgrading to paid tiers for higher limits
